{
  "name": "@tpt/sdk-web",
  "version": "0.1.0",
  "description": "TPT SDK/Web — TypeScript client for TPT Keystone's Canvas HTTP/JSON query bridge and Flux WebSocket stream (Phase 14).",
  "license": "MIT OR Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    }
  },
  "bin": {
    "tpt-typegen": "./dist/bin/typegen.js",
    "tpt-plugin-publish": "./dist/bin/plugin-publish.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "pretest": "npm run build",
    "test": "find dist -name '*.test.js' -print0 | xargs -0 node --test"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "typescript": "^5.5.4"
  }
}
