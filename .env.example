# Copy this file to `.env` (same directory as docker-compose.yml) and fill in
# real values before running `docker compose up`. These become the initial
# superuser role, seeded into the (otherwise empty) `_tpt_roles` catalog —
# once set, every listener (Postgres wire, HTTP, WebSocket, gRPC, MCP)
# requires real authentication instead of the engine's zero-config default.
#
# Generate a strong password, e.g.:
#   openssl rand -base64 24

TPT_AUTH_BOOTSTRAP_USER=admin
TPT_AUTH_BOOTSTRAP_PASSWORD=changeme-generate-a-real-secret
